# ============================================================
# KaruWeed - Environment Variables Template
# ============================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
#
# Rule: Only EXPO_PUBLIC_* vars are safe for the client bundle.
# Anything else MUST live in Supabase Edge Function secrets.
# ============================================================

# --- Supabase (client-side, anon key is protected by RLS) ---
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# --- Optional client-side keys (add when monetizing) ---
# EXPO_PUBLIC_ADMOB_ANDROID_APP_ID=
# EXPO_PUBLIC_ADMOB_IOS_APP_ID=
# EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=
# EXPO_PUBLIC_REVENUECAT_IOS_KEY=

# ============================================================
# SECRETS (NEVER put here, configure as Edge Function secrets)
# ============================================================
# ANTHROPIC_API_KEY       -> supabase secrets set ANTHROPIC_API_KEY=...
# SUPABASE_SERVICE_ROLE   -> auto-injected in Edge Functions
# STRIPE_SECRET_KEY       -> supabase secrets set STRIPE_SECRET_KEY=...
# STRIPE_WEBHOOK_SECRET   -> supabase secrets set STRIPE_WEBHOOK_SECRET=...
# GOOGLE_MAPS_API_KEY     -> restricted by bundle ID in Google Console,
#                            injected at build time via EAS secrets
